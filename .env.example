# Copy to ~/Library/Application Support/macontrol/config.env (the `macontrol
# setup` wizard does this for you). Keep the real file out of git — .env is
# in .gitignore.

# Token from @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to control the Mac.
# Get your ID from @userinfobot.
ALLOWED_USER_IDS=

# Logging — debug | info | warn | error
LOG_LEVEL=info

# Optional: override config path (defaults to
# ~/Library/Application Support/macontrol/config.env)
# MACONTROL_CONFIG=

# Optional: override log path (defaults to
# ~/Library/Logs/macontrol/macontrol.log)
# MACONTROL_LOG=
